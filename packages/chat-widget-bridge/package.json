{
  "name": "@bootdesk/chat-widget-bridge",
  "version": "0.4.44",
  "description": "Iframe bridge for BootDesk Chat SDK - enables embedding the chat widget in an iframe with cross-frame communication via postMessage",
  "repository": "https://github.com/bootdesk/chat-sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./embed-chat": {
      "import": "./dist/embed-chat.js",
      "require": "./dist/embed-chat.cjs"
    },
    "./shim": {
      "import": "./dist/shim.js",
      "require": "./dist/shim.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out ../../docs/_build/js/bridge src"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  }
}
