{
    "name": "bootdesk/adapter-web",
    "description": "Web adapter for bootdesk/core — browser chat UI via JSON request/response",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "bootdesk/core": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Web\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Web\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
