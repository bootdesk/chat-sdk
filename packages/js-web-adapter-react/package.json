{
  "name": "@bootdesk/js-web-adapter-react",
  "version": "0.4.4",
  "description": "React components for BootDesk Chat SDK WebAdapter",
  "repository": "https://github.com/bootdesk/chat-sdk",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -i ./src/styles/tailwind.css -o ./dist/styles.css --minify",
    "build:dev": "tsup && tailwindcss -i ./src/styles/tailwind.css -o ./dist/styles.css",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out ../../docs/_build/js/react src"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@bootdesk/js-web-adapter-core": "^0.4.4",
    "marked": "^18.0.0",
    "dompurify": "^3.4.5",
    "@bootdesk/chat-widget-bridge": "^0.4.4"
  },
  "peerDependenciesMeta": {
    "@bootdesk/chat-widget-bridge": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bootdesk/js-web-adapter-core": "*",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/dompurify": "^3.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "dompurify": "^3.4.5",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.0",
    "marked": "^18.0.0",
    "prettier": "^3.8.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  }
}
