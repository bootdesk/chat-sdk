{
  "name": "@bootdesk/chat-widget-react-native",
  "version": "0.1.0",
  "description": "React Native WebView wrapper for BootDesk Chat Widget - bridges native push (FCM/APNs) with the JS chat widget",
  "repository": "https://github.com/bootdesk/chat-sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.73.0",
    "react-native-webview": "^13.0.0"
  },
  "dependencies": {
    "@bootdesk/chat-widget-bridge": "^0.3.3"
  },
  "devDependencies": {
    "@bootdesk/chat-widget-bridge": "*",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "react": "^18.0.0",
    "react-native": "^0.86.0",
    "react-native-webview": "^13.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4"
  }
}
