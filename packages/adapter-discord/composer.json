{
    "name": "bootdesk/adapter-discord",
    "description": "Discord adapter for bootdesk/core",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "bootdesk/core": "*",
        "ext-json": "*",
        "ext-sodium": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Discord\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Discord\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
