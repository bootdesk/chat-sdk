{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "bootdesk/chat-sdk-adapter-web",
  "description": "Web adapter for bootdesk/chat-sdk-core — browser chat UI via JSON request/response",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "bootdesk/chat-sdk-core": "0.4.18",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "BootDesk\\ChatSDK\\Web\\": "src/"
    },
    "files": [
      "src/register.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "BootDesk\\ChatSDK\\Web\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "version": "0.4.18"
}
