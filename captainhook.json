{
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "npm run format -w @bootdesk/js-web-adapter-core -w @bootdesk/js-web-adapter-react && composer format && git add -u"
            },
            {
                "action": "composer lint"
            },
            {
                "action": "composer analyse"
            },
            {
                "action": "composer test"
            }
        ]
    }
}
