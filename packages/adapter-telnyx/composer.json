{
    "name": "bootdesk/adapter-telnyx",
    "description": "Telnyx adapter for bootdesk/core (SMS, MMS, RCS)",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "bootdesk/core": "*",
        "ext-json": "*",
        "ext-sodium": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Telnyx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Telnyx\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": []
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
