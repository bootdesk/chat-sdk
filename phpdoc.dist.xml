<?xml version="1.0" encoding="UTF-8"?>
<phpdocumentor configVersion="3">
  <title>bootdesk/chat-sdk</title>
  <use-cache>false</use-cache>
  <paths>
    <output>docs/_build</output>
  </paths>
  <setting name="template.color" value="blue"/>
  <versions>
    <version>
      <number>1.0.0</number>
      <apis>
        <api>
          <default-package-name>BootDesk</default-package-name>
          <source>
            <dsn>.</dsn>
            <paths>
              <path>packages/*/src</path>
            </paths>
          </source>
        </api>
      </apis>
      <guides>
        <guide>
          <format>md</format>
          <source dsn=".">
            <path>docs/guide</path>
          </source>
          <output>guide</output>
        </guide>
      </guides>
    </version>
  </versions>
</phpdocumentor>
