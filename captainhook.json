{
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "bash scripts/format-staged.sh"
            },
            {
                "action": "npm test -w @bootdesk/js-web-adapter-core -w @bootdesk/js-web-adapter-react"
            },
            {
                "action": "composer lint"
            },
            {
                "action": "composer analyse"
            },
            {
                "action": "composer test"
            }
        ]
    }
}
