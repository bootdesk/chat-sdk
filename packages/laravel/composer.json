{
    "name": "bootdesk/laravel",
    "type": "library",
    "description": "Laravel integration for the PHP Chat SDK",
    "require": {
        "php": ">=8.2",
        "bootdesk/core": "^1.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "symfony/psr-http-message-bridge": "^2.0|^3.0",
        "nyholm/psr7": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BootDesk\\ChatSDK\\Laravel\\ChatServiceProvider"
            ],
            "aliases": {
                "Chat": "BootDesk\\ChatSDK\\Laravel\\ChatFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
