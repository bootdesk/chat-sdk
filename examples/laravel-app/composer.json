{
    "name": "example/bootdesk-chat-app",
    "description": "Example Laravel app using bootdesk",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "laravel/framework": "^11.0",
        "bootdesk/chat-sdk-laravel": "*",
        "bootdesk/chat-sdk-adapter-slack": "*",
        "bootdesk/chat-sdk-adapter-telegram": "*",
        "bootdesk/chat-sdk-adapter-discord": "*",
        "bootdesk/chat-sdk-adapter-whatsapp": "*",
        "bootdesk/chat-sdk-adapter-github": "*",
        "bootdesk/chat-sdk-botman-compat": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
