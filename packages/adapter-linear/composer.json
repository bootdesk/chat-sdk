{
    "name": "bootdesk/adapter-linear",
    "description": "Linear adapter for bootdesk/core",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "bootdesk/core": "*",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Linear\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Linear\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
