{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "bootdesk/chat-sdk-adapter-telegram",
  "description": "Telegram adapter for bootdesk/chat-sdk-core",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "bootdesk/chat-sdk-core": "^0.3.1",
    "ext-json": "*",
    "php-http/multipart-stream-builder": "^1.4",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "symfony/polyfill-php83": "^1.37"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "BootDesk\\ChatSDK\\Telegram\\": "src/"
    },
    "files": [
      "src/register.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "BootDesk\\ChatSDK\\Telegram\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "version": "0.3.1"
}
