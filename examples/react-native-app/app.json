{
  "expo": {
    "name": "Chat Widget",
    "slug": "chat-widget-example",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bootdesk.chatexample",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.bootdesk.chatexample",
      "adaptiveIcon": null
    },
    "plugins": ["expo-dev-client"]
  }
}
