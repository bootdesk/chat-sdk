{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bootdesk/chat-sdk",
    "type": "library",
    "description": "Multi-platform chat bot SDK for PHP — Slack, Telegram, WhatsApp, Discord, Messenger, Web, GitHub, Linear, Telnyx + Laravel integration + BotMan compatibility",
    "require": {
        "php": ">=8.2",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^1.0|^2.0|^3.0",
        "league/commonmark": "^2.0",
        "ramsey/uuid": "^4.0|^5.0",
        "nyholm/psr7": "^1.0",
        "symfony/psr-http-message-bridge": "^5.4|^6.0|^6.4|^7.0|^8.0",
        "php-http/multipart-stream-builder": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4",
        "captainhook/captainhook": "^5.29",
        "phpdocumentor/shim": "*"
    },
    "autoload": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Core\\": "packages/core/src/",
            "BootDesk\\ChatSDK\\Laravel\\": "packages/laravel/src/",
            "BootDesk\\ChatSDK\\Slack\\": "packages/adapter-slack/src/",
            "BootDesk\\ChatSDK\\Telegram\\": "packages/adapter-telegram/src/",
            "BootDesk\\ChatSDK\\WhatsApp\\": "packages/adapter-whatsapp/src/",
            "BootDesk\\ChatSDK\\Discord\\": "packages/adapter-discord/src/",
            "BootDesk\\ChatSDK\\Web\\": "packages/adapter-web/src/",
            "BootDesk\\ChatSDK\\Messenger\\": "packages/adapter-messenger/src/",
            "BootDesk\\ChatSDK\\GitHub\\": "packages/adapter-github/src/",
            "BootDesk\\ChatSDK\\Linear\\": "packages/adapter-linear/src/",
            "BootDesk\\ChatSDK\\Telnyx\\": "packages/adapter-telnyx/src/",
            "BotMan\\BotMan\\": "packages/botman-compat/src/"
        },
        "files": [
            "packages/adapter-slack/src/register.php",
            "packages/adapter-telegram/src/register.php",
            "packages/adapter-whatsapp/src/register.php",
            "packages/adapter-discord/src/register.php",
            "packages/adapter-messenger/src/register.php",
            "packages/adapter-github/src/register.php",
            "packages/adapter-linear/src/register.php",
            "packages/adapter-telnyx/src/register.php",
            "packages/adapter-web/src/register.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "BootDesk\\ChatSDK\\Core\\Tests\\": "packages/core/tests/",
            "BootDesk\\ChatSDK\\Laravel\\Tests\\": "packages/laravel/tests/",
            "BootDesk\\ChatSDK\\Slack\\Tests\\": "packages/adapter-slack/tests/",
            "BootDesk\\ChatSDK\\Telegram\\Tests\\": "packages/adapter-telegram/tests/",
            "BootDesk\\ChatSDK\\WhatsApp\\Tests\\": "packages/adapter-whatsapp/tests/",
            "BootDesk\\ChatSDK\\Discord\\Tests\\": "packages/adapter-discord/tests/",
            "BootDesk\\ChatSDK\\Web\\Tests\\": "packages/adapter-web/tests/",
            "BootDesk\\ChatSDK\\Messenger\\Tests\\": "packages/adapter-messenger/tests/",
            "BootDesk\\ChatSDK\\GitHub\\Tests\\": "packages/adapter-github/tests/",
            "BootDesk\\ChatSDK\\Linear\\Tests\\": "packages/adapter-linear/tests/",
            "BootDesk\\ChatSDK\\Telnyx\\Tests\\": "packages/adapter-telnyx/tests/",
            "BotMan\\BotMan\\Tests\\": "packages/botman-compat/tests/"
        },
        "files": [
            "packages/core/tests/Helpers/functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/phpunit -c phpunit.coverage.xml",
        "test:coverage:ci": "@test:coverage --coverage-clover coverage/clover.xml",
        "analyse": "phpstan analyse --memory-limit=1G -v",
        "format": "rector process",
        "format:check": "rector process --dry-run",
        "lint": "pint --test",
        "lint:fix": "pint",
        "all": [
            "@lint",
            "@analyse",
            "@test"
        ],
        "check": [
            "@lint",
            "@analyse",
            "@test:coverage"
        ],
        "docs": "vendor/bin/phpdoc -c phpdoc.dist.xml"
    },
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpdocumentor/shim": true
        }
    }
}
